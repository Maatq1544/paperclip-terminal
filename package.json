{
  "name": "@paperclipai/plugin-terminal",
  "version": "1.0.0",
  "description": "Interactive server terminal plugin for Paperclip — execute shell commands and manage PTY sessions directly from the project view.",
  "keywords": ["paperclip", "paperclip-plugin", "terminal", "shell", "pty", "server"],
  "author": "Paperclip Community",
  "license": "MIT",
  "type": "module",
  "private": false,
  "main": "./dist/worker.js",
  "module": "./dist/worker.js",
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "prebuild": "node scripts/ensure-deps.mjs 2>/dev/null || true",
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "^2026.325.0",
    "uuid": "^9.0.1"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/uuid": "^9.0.8",
    "esbuild": "^0.24.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
